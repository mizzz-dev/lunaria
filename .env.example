# =============================================
# Lunaria - Environment Variables Example
# Copy this file to .env and fill in values
# =============================================

# ----- App -----
NODE_ENV=development
LOG_LEVEL=info

# ----- PostgreSQL -----
POSTGRES_USER=lunaria
POSTGRES_PASSWORD=lunaria_dev_password
POSTGRES_DB=lunaria
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=lunaria_redis_password
REDIS_URL="redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}"

# ----- Discord Bot -----
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# Bot slash command guild (for dev-only registration; leave empty for global)
DISCORD_DEV_GUILD_ID=

# ----- Discord OAuth2 (for Dashboard) -----
# Redirect URI registered in Discord Developer Portal
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback/discord

# ----- API Server -----
API_PORT=4000
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:4000
API_CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_KEY_PREFIX=rl:api

# JWT signing secret (generate with: openssl rand -base64 64)
JWT_SECRET=replace_with_secure_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# Cookie secret (generate with: openssl rand -base64 32)
COOKIE_SECRET=replace_with_secure_random_cookie_secret

# ----- Dashboard -----
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_secure_random_nextauth_secret

# ----- Worker -----
WORKER_CONCURRENCY=5

# ----- Internal Bot ↔ API Secret -----
# Shared secret for bot-to-API requests (generate with: openssl rand -base64 32)
BOT_INTERNAL_SECRET=replace_with_secure_random_bot_internal_secret

