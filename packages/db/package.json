{
  "name": "@lunaria/db",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma client and database utilities for Lunaria",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "generate": "prisma generate --schema=../../prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0"
  },
  "devDependencies": {
    "prisma": "^5.15.0",
    "typescript": "*"
  }
}
