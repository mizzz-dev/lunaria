// =============================================
// Lunaria - Prisma Schema
// All Discord snowflakes stored as String
// Internal PKs use cuid()
// =============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// Core Auth
// =============================================

model User {
  id             String    @id @default(cuid())
  discordId      String    @unique
  username       String
  discriminator  String    @default("0")
  avatar         String?
  email          String?
  globalName     String?
  // Encrypted tokens - never expose directly
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  memberships     GuildMembership[]
  roleAssignments GuildMemberRoleAssignment[]
  auditLogs       AuditLog[]
  reminders       Reminder[]
  consentRecords  ConsentRecord[]
  gameLinks       GameLink[]

  @@map("users")
}

model Guild {
  id          String    @id @default(cuid())
  discordId   String    @unique
  name        String
  icon        String?
  ownerId     String    // Discord snowflake of guild owner
  botJoinedAt DateTime?
  active      Boolean   @default(true)
  dashboardLayout Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  memberships       GuildMembership[]
  pluginSettings    GuildPluginSetting[]
  configVersions    ConfigVersion[]
  auditLogs         AuditLog[]
  rbacRoles         RbacRole[]
  rules             Rule[]
  ruleRuns          RuleRun[]
  autoResponses     AutoResponse[]
  quotes            Quote[]
  dailyContentJobs  DailyContentJob[]
  polls             Poll[]
  events            Event[]
  lfgPosts          LfgPost[]
  teamSets          TeamSet[]
  faqArticles       FaqArticle[]
  reminders         Reminder[]
  moderationRules   ModerationRule[]
  moderationActions ModerationAction[]
  analyticsEvents   AnalyticsEvent[]
  analyticsDaily    AnalyticsDaily[]
  templates         Template[]
  externalServers   ExternalServer[]

  @@map("guilds")
}

model GuildMembership {
  id           String    @id @default(cuid())
  guildId      String
  userId       String
  discordRoles String[]  // Discord role snowflakes cached from Discord API
  nickname     String?
  joinedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  roleAssignments GuildMemberRoleAssignment[]

  @@unique([guildId, userId])
  @@index([guildId])
  @@index([userId])
  @@map("guild_memberships")
}

// =============================================
// Plugin Registry
// =============================================

model Plugin {
  id          String  @id @default(cuid())
  pluginKey   String  @unique
  name        String
  description String
  version     String
  // Config JSON schema (JSON Schema Draft 7 compatible)
  configSchema Json    @default("{}")
  // Audit event definitions
  auditEvents  String[] @default([])
  // Billing tier: "free" | "pro" | "enterprise"
  billingTier  String  @default("free")
  // Whether this plugin is installable
  active       Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dependenciesFrom PluginDependency[] @relation("DependencyFrom")
  dependenciesTo   PluginDependency[] @relation("DependencyTo")
  guildSettings    GuildPluginSetting[]

  @@map("plugins")
}

model PluginDependency {
  id             String @id @default(cuid())
  pluginId       String
  dependsOnId    String

  plugin    Plugin @relation("DependencyFrom", fields: [pluginId], references: [id], onDelete: Cascade)
  dependsOn Plugin @relation("DependencyTo", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([pluginId, dependsOnId])
  @@map("plugin_dependencies")
}

model GuildPluginSetting {
  id        String   @id @default(cuid())
  guildId   String
  pluginId  String
  enabled   Boolean  @default(false)
  // Plugin-specific config (validated against plugin.configSchema)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild  Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  plugin Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([guildId, pluginId])
  @@index([guildId])
  @@map("guild_plugin_settings")
}

// =============================================
// Config Versioning
// =============================================

model ConfigVersion {
  id          String   @id @default(cuid())
  guildId     String
  // "plugin:{pluginKey}" | "rule:{ruleId}" | "guild_settings" etc.
  scope       String
  version     Int
  snapshot    Json
  // Who made the change (userId or "system")
  changedBy   String
  changeNote  String?
  createdAt   DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, scope])
  @@map("config_versions")
}

// =============================================
// Audit Log
// =============================================

model AuditLog {
  id          String   @id @default(cuid())
  guildId     String
  actorId     String?  // userId (null = system/bot)
  actorType   String   @default("user") // "user" | "bot" | "system"
  action      String   // e.g. "plugin.enable", "rule.create", "quote.delete"
  targetType  String?  // e.g. "plugin", "rule", "quote"
  targetId    String?
  before      Json?
  after       Json?
  metadata    Json     @default("{}")
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  guild Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  actor User?  @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([guildId, action])
  @@index([guildId, createdAt])
  @@map("audit_logs")
}

// =============================================
// RBAC
// =============================================

model RbacRole {
  id          String   @id @default(cuid())
  guildId     String
  name        String
  description String?
  // System roles cannot be deleted/modified: "owner", "admin", "moderator", "member"
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild       Guild                      @relation(fields: [guildId], references: [id], onDelete: Cascade)
  permissions RbacRolePermission[]
  assignments GuildMemberRoleAssignment[]

  @@unique([guildId, name])
  @@index([guildId])
  @@map("rbac_roles")
}

model RbacPermission {
  id          String  @id @default(cuid())
  key         String  @unique
  description String
  // "plugin" | "rule" | "quote" | "audit" | "config" | "moderation" | "analytics" | "rbac"
  category    String

  roles RbacRolePermission[]

  @@map("rbac_permissions")
}

model RbacRolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       RbacRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission RbacPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("rbac_role_permissions")
}

model GuildMemberRoleAssignment {
  id           String   @id @default(cuid())
  membershipId String
  roleId       String
  userId       String
  assignedBy   String?  // userId
  createdAt    DateTime @default(now())

  membership GuildMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role       RbacRole        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([membershipId, roleId])
  @@map("guild_member_role_assignments")
}

// =============================================
// Rule Engine
// =============================================

model Rule {
  id          String   @id @default(cuid())
  guildId     String
  name        String
  description String?
  enabled     Boolean  @default(true)
  // Trigger type: "messageCreate" | "memberJoin" | "reactionAdd" | "scheduled" | "buttonClick" | "slashCommandExecuted"
  trigger     String
  triggerConfig Json   @default("{}")
  // Conditions array (JSON): [{type, config}]
  conditions  Json     @default("[]")
  // Actions array (JSON): [{type, config}]
  actions     Json     @default("[]")
  // Execution order for same-trigger rules
  priority    Int      @default(0)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  runs  RuleRun[]

  @@index([guildId, enabled])
  @@index([guildId, trigger])
  @@map("rules")
}

model RuleRun {
  id         String   @id @default(cuid())
  guildId    String
  ruleId     String
  // "success" | "skipped" | "error"
  status     String
  trigger    String
  context    Json     @default("{}")
  actionsRan Json     @default("[]")
  error      String?
  durationMs Int?
  createdAt  DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  rule  Rule  @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([guildId, createdAt])
  @@index([ruleId])
  @@map("rule_runs")
}

// =============================================
// Auto Response
// =============================================

model AutoResponse {
  id            String   @id @default(cuid())
  guildId       String
  name          String
  enabled       Boolean  @default(true)
  // "keyword" | "regex" | "startsWith" | "exact"
  matchType     String   @default("keyword")
  pattern       String
  // "reply" | "react" | "dm" | "thread_reply"
  responseType  String   @default("reply")
  response      String
  // Channel IDs to restrict (empty = all channels)
  channelIds    String[] @default([])
  // Role IDs that trigger this (empty = all roles)
  triggerRoles  String[] @default([])
  ignoreBots    Boolean  @default(true)
  caseSensitive Boolean  @default(false)
  cooldownSec   Int      @default(0)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, enabled])
  @@map("auto_responses")
}

// =============================================
// Quotes
// =============================================

model Quote {
  id          String   @id @default(cuid())
  guildId     String
  content     String
  author      String   // Display name
  authorId    String?  // Discord snowflake
  addedBy     String?  // Discord snowflake of who added
  channelId   String?
  messageId   String?
  attachments String[] @default([])
  tags        String[] @default([])
  deleted     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild   Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  reports QuoteReport[]

  @@index([guildId])
  @@map("quotes")
}

model QuoteReport {
  id         String   @id @default(cuid())
  quoteId    String
  reportedBy String   // Discord snowflake
  reason     String
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_reports")
}

// =============================================
// Daily Content
// =============================================

model DailyContentJob {
  id           String   @id @default(cuid())
  guildId      String
  name         String
  enabled      Boolean  @default(true)
  channelId    String
  // "quote" | "tip" | "custom"
  contentType  String   @default("quote")
  // Cron expression
  cronExpr     String   @default("0 9 * * *")
  timezone     String   @default("UTC")
  // Template message (supports {content}, {author} placeholders)
  template     String?
  tags         String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  guild Guild            @relation(fields: [guildId], references: [id], onDelete: Cascade)
  runs  DailyContentRun[]

  @@index([guildId])
  @@map("daily_content_jobs")
}

model DailyContentRun {
  id        String   @id @default(cuid())
  jobId     String
  // "success" | "error" | "skipped"
  status    String
  messageId String?
  error     String?
  createdAt DateTime @default(now())

  job DailyContentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("daily_content_runs")
}

// =============================================
// Polls
// =============================================

model Poll {
  id          String    @id @default(cuid())
  guildId     String
  channelId   String
  messageId   String?
  title       String
  description String?
  // "single" | "multi"
  voteType    String    @default("single")
  anonymous   Boolean   @default(false)
  endsAt      DateTime?
  closed      Boolean   @default(false)
  createdBy   String    // Discord snowflake
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  guild   Guild        @relation(fields: [guildId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]

  @@index([guildId])
  @@map("polls")
}

model PollOption {
  id       String @id @default(cuid())
  pollId   String
  label    String
  emoji    String?
  position Int    @default(0)

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  id       String   @id @default(cuid())
  pollId   String
  optionId String
  voterId  String   // Discord snowflake
  createdAt DateTime @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([pollId, optionId, voterId])
  @@index([pollId])
  @@map("poll_votes")
}

// =============================================
// Events
// =============================================

model Event {
  id           String    @id @default(cuid())
  guildId      String
  channelId    String?
  title        String
  description  String?
  location     String?
  startsAt     DateTime
  endsAt       DateTime?
  maxParticipants Int?
  // "open" | "cancelled" | "completed"
  status       String    @default("open")
  // "public" | "role_restricted"
  visibility   String    @default("public")
  allowedRoles String[]  @default([])
  createdBy    String    // Discord snowflake
  messageId    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  guild        Guild              @relation(fields: [guildId], references: [id], onDelete: Cascade)
  participants EventParticipant[]

  @@index([guildId])
  @@map("events")
}

model EventParticipant {
  id        String   @id @default(cuid())
  eventId   String
  userId    String   // Discord snowflake
  // "going" | "maybe" | "declined"
  status    String   @default("going")
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("event_participants")
}

// =============================================
// LFG (Looking for Group)
// =============================================

model LfgPost {
  id          String    @id @default(cuid())
  guildId     String
  channelId   String?
  messageId   String?
  title       String
  description String?
  game        String?
  // "open" | "full" | "closed"
  status      String    @default("open")
  maxPlayers  Int?
  expiresAt   DateTime?
  createdBy   String    // Discord snowflake
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  guild   Guild      @relation(fields: [guildId], references: [id], onDelete: Cascade)
  entries LfgEntry[]

  @@index([guildId, status])
  @@map("lfg_posts")
}

model LfgEntry {
  id        String   @id @default(cuid())
  lfgId     String
  userId    String   // Discord snowflake
  note      String?
  joinedAt  DateTime @default(now())

  lfg LfgPost @relation(fields: [lfgId], references: [id], onDelete: Cascade)

  @@unique([lfgId, userId])
  @@index([lfgId])
  @@map("lfg_entries")
}

// =============================================
// Team Split
// =============================================

model TeamSet {
  id         String   @id @default(cuid())
  guildId    String
  name       String
  // "random" | "balanced" | "manual"
  splitMode  String   @default("random")
  teamCount  Int      @default(2)
  // "open" | "dissolved"
  status     String   @default("open")
  createdBy  String   // Discord snowflake
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  guild Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  teams Team[]

  @@index([guildId])
  @@map("team_sets")
}

model Team {
  id        String @id @default(cuid())
  teamSetId String
  name      String
  color     String?
  position  Int    @default(0)

  teamSet TeamSet      @relation(fields: [teamSetId], references: [id], onDelete: Cascade)
  members TeamMember[]

  @@index([teamSetId])
  @@map("teams")
}

model TeamMember {
  id       String @id @default(cuid())
  teamId   String
  userId   String // Discord snowflake
  role     String @default("member") // "captain" | "member"

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

// =============================================
// FAQ / Knowledge Base
// =============================================

model FaqArticle {
  id          String   @id @default(cuid())
  guildId     String
  title       String
  content     String
  tags        String[] @default([])
  // "published" | "draft" | "archived"
  status      String   @default("published")
  viewCount   Int      @default(0)
  helpful     Int      @default(0)
  notHelpful  Int      @default(0)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild    Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  feedback FaqFeedback[]

  @@index([guildId, status])
  @@map("faq_articles")
}

model FaqFeedback {
  id        String   @id @default(cuid())
  articleId String
  userId    String   // Discord snowflake
  // "helpful" | "not_helpful"
  rating    String
  comment   String?
  createdAt DateTime @default(now())

  article FaqArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@map("faq_feedback")
}

// =============================================
// Reminders
// =============================================

model Reminder {
  id         String    @id @default(cuid())
  guildId    String
  userId     String    // internal User id
  channelId  String?   // Discord channel snowflake (null = DM)
  content    String
  remindAt   DateTime
  sent       Boolean   @default(false)
  sentAt     DateTime?
  // "once" | "daily" | "weekly"
  recurrence String    @default("once")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([remindAt, sent])
  @@map("reminders")
}

// =============================================
// Moderation
// =============================================

model ModerationRule {
  id          String   @id @default(cuid())
  guildId     String
  name        String
  enabled     Boolean  @default(true)
  // "spam" | "banned_word" | "link_filter" | "mention_spam" | "caps_abuse" | "duplicate_message"
  ruleType    String
  config      Json     @default("{}")
  // Action: "warn" | "mute" | "kick" | "ban" | "delete" | "log"
  action      String   @default("warn")
  actionConfig Json    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild   Guild              @relation(fields: [guildId], references: [id], onDelete: Cascade)
  actions ModerationAction[]

  @@index([guildId, enabled])
  @@map("moderation_rules")
}

model ModerationAction {
  id          String   @id @default(cuid())
  guildId     String
  ruleId      String?
  // "warn" | "mute" | "kick" | "ban" | "unban" | "unmute" | "delete_message" | "manual"
  actionType  String
  targetId    String   // Discord snowflake of the target user
  moderatorId String?  // Discord snowflake (null = automated)
  reason      String?
  expiresAt   DateTime?
  reversed    Boolean  @default(false)
  reversedAt  DateTime?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  guild Guild          @relation(fields: [guildId], references: [id], onDelete: Cascade)
  rule  ModerationRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([guildId, targetId])
  @@index([guildId, createdAt])
  @@map("moderation_actions")
}

// =============================================
// Analytics
// =============================================

model AnalyticsEvent {
  id        String   @id @default(cuid())
  guildId   String
  // "message" | "member_join" | "member_leave" | "voice_join" | "voice_leave"
  // "command_used" | "poll_vote" | "event_join" | "lfg_join" | "moderation_action"
  eventType String
  userId    String?  // Discord snowflake
  channelId String?
  metadata  Json     @default("{}")
  occurredAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, eventType, occurredAt])
  @@map("analytics_events")
}

model AnalyticsDaily {
  id          String   @id @default(cuid())
  guildId     String
  date        DateTime // Truncated to date
  // Aggregated metrics for the day
  metrics     Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, date])
  @@index([guildId])
  @@map("analytics_daily")
}

// =============================================
// Templates
// =============================================

model Template {
  id          String   @id @default(cuid())
  guildId     String?  // null = global template
  name        String
  description String?
  // "rule" | "auto_response" | "poll" | "event" | "faq" | "moderation"
  category    String
  // Template body (matches the config shape of the target entity)
  body        Json
  tags        String[] @default([])
  // "official" | "community" | "private"
  visibility  String   @default("private")
  createdBy   String?
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild        Guild?               @relation(fields: [guildId], references: [id], onDelete: Cascade)
  applications TemplateApplication[]

  @@index([category, visibility])
  @@map("templates")
}

model TemplateApplication {
  id         String   @id @default(cuid())
  templateId String
  guildId    String
  appliedBy  String?
  // ID of the entity created by applying this template
  resultId   String?
  resultType String?
  createdAt  DateTime @default(now())

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([guildId])
  @@map("template_applications")
}

// =============================================
// Stubs: External integrations (safe boundaries)
// =============================================

// Stub: HoYo / Game Account Links
// Not production-connected. Stores consent and verified game IDs only.
model GameLink {
  id           String   @id @default(cuid())
  userId       String
  // "hoyoverse" | "riot" | "steam"
  platform     String
  // Platform-specific user ID (e.g. HoYoverse UID)
  platformId   String
  displayName  String?
  verified     Boolean  @default(false)
  verifiedAt   DateTime?
  // Encrypted; nullable until actual API connection is implemented
  accessToken  String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("game_links")
}

// Stub: Voice Record Consent
// Stores explicit user consent records; no actual audio is stored in MVP
model ConsentRecord {
  id          String   @id @default(cuid())
  userId      String
  guildId     String
  // "voice_record" | "data_processing" | "external_share"
  consentType String
  granted     Boolean
  grantedAt   DateTime @default(now())
  revokedAt   DateTime?
  ipAddress   String?
  userAgent   String?
  metadata    Json     @default("{}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType])
  @@index([guildId, consentType])
  @@map("consent_records")
}

