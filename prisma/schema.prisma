  guildId     String
  name        String
  // "minecraft" | "valheim" | "custom"
  serverType  String
  host        String?
  port        Int?
  // "unknown" | "online" | "offline" | "starting" | "stopping"
  status      String   @default("unknown")
  // Encrypted credentials placeholder
